<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="6dof_arm">

  <xacro:property name="base_width"      value="0.090"/>
  <xacro:property name="base_depth"      value="0.088"/>
  <xacro:property name="base_height"     value="0.084"/>
  <xacro:property name="upper_arm_len"   value="0.130"/>
  <xacro:property name="forearm_len"     value="0.083"/>
  <xacro:property name="wrist_len"       value="0.060"/>
  <xacro:property name="gripper_len"     value="0.047"/>
  <xacro:property name="finger_len"      value="0.055"/>
  <xacro:property name="link_width"      value="0.040"/>
  <xacro:property name="servo_w"         value="0.040"/>
  <xacro:property name="servo_h"         value="0.038"/>
  <xacro:property name="servo_d"         value="0.020"/>

  <material name="black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <geometry><box size="${base_width} ${base_depth} 0.005"/></geometry>
      <origin xyz="0 0 0.0025" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><box size="${base_width} ${base_depth} 0.005"/></geometry>
      <origin xyz="0 0 0.0025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.0025" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <!-- BASE ROTATION (Joint 0) -->
  <joint name="base_rotation_joint" type="revolute">
    <parent link="base_link"/>
    <child link="base_turntable"/>
    <origin xyz="0 0 0.005" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="5.0" velocity="1.0"/>
  </joint>

  <link name="base_turntable">
    <visual>
      <geometry><cylinder radius="0.035" length="${base_height}"/></geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.035" length="${base_height}"/></geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- SHOULDER SERVO -->
  <joint name="shoulder_servo_mount" type="fixed">
    <parent link="base_turntable"/>
    <child link="shoulder_servo"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <link name="shoulder_servo">
    <visual>
      <geometry><box size="${servo_w} ${servo_d} ${servo_h}"/></geometry>
      <origin xyz="0 0 ${servo_h/2}" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.055"/>
      <origin xyz="0 0 ${servo_h/2}" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- SHOULDER (Joint 1) -->
  <joint name="shoulder_joint" type="revolute">
    <parent link="shoulder_servo"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 ${servo_h/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="1.0"/>
  </joint>

  <link name="upper_arm">
    <visual>
      <geometry><box size="${link_width} 0.020 ${upper_arm_len}"/></geometry>
      <origin xyz="0 0 ${upper_arm_len/2}" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><box size="${link_width} 0.020 ${upper_arm_len}"/></geometry>
      <origin xyz="0 0 ${upper_arm_len/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 ${upper_arm_len/2}" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- ELBOW (Joint 2) -->
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0 0 ${upper_arm_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="1.0"/>
  </joint>

  <link name="forearm">
    <visual>
      <geometry><box size="${link_width} 0.020 ${forearm_len}"/></geometry>
      <origin xyz="0 0 ${forearm_len/2}" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><box size="${link_width} 0.020 ${forearm_len}"/></geometry>
      <origin xyz="0 0 ${forearm_len/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 ${forearm_len/2}" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00003"/>
    </inertial>
  </link>

  <!-- WRIST PITCH (Joint 3) -->
  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="forearm"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0 0 ${forearm_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="3.0" velocity="1.0"/>
  </joint>

  <link name="wrist_pitch_link">
    <visual>
      <geometry><box size="0.035 0.025 ${wrist_len}"/></geometry>
      <origin xyz="0 0 ${wrist_len/2}" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><box size="0.035 0.025 ${wrist_len}"/></geometry>
      <origin xyz="0 0 ${wrist_len/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 ${wrist_len/2}" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <!-- WRIST ROLL (Joint 4) -->
  <joint name="wrist_roll_joint" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0 0 ${wrist_len}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="3.0" velocity="1.0"/>
  </joint>

  <link name="wrist_roll_link">
    <visual>
      <geometry><cylinder radius="0.018" length="${gripper_len}"/></geometry>
      <origin xyz="0 0 ${gripper_len/2}" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.018" length="${gripper_len}"/></geometry>
      <origin xyz="0 0 ${gripper_len/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 ${gripper_len/2}" rpy="0 0 0"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- GRIPPER BASE (fixed to wrist roll) -->
  <joint name="gripper_base_joint" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 ${gripper_len}" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <geometry><box size="0.030 0.040 0.015"/></geometry>
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.04"/>
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- LEFT FINGER (slides along Y) -->
  <joint name="finger_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="finger_left"/>
    <origin xyz="0 -0.008 0.015" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.015" effort="1.0" velocity="0.5"/>
  </joint>

  <link name="finger_left">
    <visual>
      <geometry><box size="0.005 0.010 ${finger_len}"/></geometry>
      <origin xyz="0 0 ${finger_len/2}" rpy="0 0 0"/>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry><box size="0.005 0.010 ${finger_len}"/></geometry>
      <origin xyz="0 0 ${finger_len/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.015"/>
      <origin xyz="0 0 ${finger_len/2}" rpy="0 0 0"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <!-- RIGHT FINGER (slides along Y) -->
  <joint name="finger_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="finger_right"/>
    <origin xyz="0 0.008 0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.015" effort="1.0" velocity="0.5"/>
    <mimic joint="finger_left_joint" multiplier="1.0" offset="0"/>
  </joint>

  <link name="finger_right">
    <visual>
      <geometry><box size="0.005 0.010 ${finger_len}"/></geometry>
      <origin xyz="0 0 ${finger_len/2}" rpy="0 0 0"/>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry><box size="0.005 0.010 ${finger_len}"/></geometry>
      <origin xyz="0 0 ${finger_len/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.015"/>
      <origin xyz="0 0 ${finger_len/2}" rpy="0 0 0"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

</robot>
